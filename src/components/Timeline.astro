---
import type { TimelineItem } from "../data/timeline";

type Props = {
  items: TimelineItem[];
};

const { items } = Astro.props;
---

<div class="relative mt-12">
  <div class="absolute left-4 top-0 hidden h-full w-px bg-gradient-to-b from-cyan-300 via-white/20 to-transparent sm:block"></div>
  <div class="grid gap-5">
    {items.map((item) => (
      <article class="section-reveal group surface-soft relative p-6 transition hover:-translate-y-1 hover:border-cyan-300/30 hover:bg-white/[0.065] sm:ml-12">
        <span class="absolute -left-[3.25rem] top-7 hidden size-8 rounded-full border border-cyan-300/40 bg-[#06141b] shadow-lg shadow-cyan-950/40 sm:grid sm:place-items-center">
          <span class="size-2.5 rounded-full bg-cyan-300"></span>
        </span>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">{item.period}</p>
        <h3 class="mt-3 text-xl font-semibold text-white">{item.title}</h3>
        <p class="mt-3 leading-7 text-slate-300">{item.description}</p>
      </article>
    ))}
  </div>
</div>
