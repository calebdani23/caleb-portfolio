---
import type { CertificationProgram } from "../data/certifications";
import SectionHeader from "./SectionHeader.astro";

type Props = {
  certifications: CertificationProgram[];
};

const { certifications } = Astro.props;
---

<section id="certificados" class="px-5 py-20 sm:px-8 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <SectionHeader
      eyebrow="Certificados"
      title="Aprendizaje autodidacta con evidencia descargable."
      description="Estos certificados refuerzan mi camino de aprendizaje independiente: soporte técnico, redes, sistemas, seguridad, Git/GitHub y hábitos de autodesarrollo."
    />

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {certifications.map((program) => (
        <article class="section-reveal rounded-[2rem] border border-white/10 bg-white/[0.04] p-5 transition duration-300 hover:-translate-y-1 hover:border-cyan-300/25 hover:bg-white/[0.055] sm:p-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-cyan-300">{program.issuer}</p>
              <h3 class="mt-3 text-2xl font-semibold leading-8 text-white">{program.title}</h3>
            </div>
            <span class="w-fit rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-semibold text-slate-300">
              {program.mainCertificates.length + program.courseCertificates.length} PDF{program.mainCertificates.length + program.courseCertificates.length > 1 ? "s" : ""}
            </span>
          </div>
          <p class="mt-4 leading-7 text-slate-300">{program.summary}</p>

          <div class="mt-6 rounded-3xl border border-cyan-300/20 bg-cyan-300/10 p-4">
            <p class="text-sm font-semibold text-cyan-100">Certificado principal del programa</p>
            <div class="mt-4 grid gap-4">
              {program.mainCertificates.map((certification) => (
                <div>
                  <h4 class="font-semibold text-white">{certification.title}</h4>
                  <p class="mt-2 text-sm leading-6 text-slate-300">{certification.focus}</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    <a href={certification.href} target="_blank" rel="noreferrer" class="inline-flex rounded-full border border-cyan-300/25 bg-cyan-300/10 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:-translate-y-0.5 hover:bg-cyan-300/15 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Abrir certificado principal ${certification.title} en PDF`}>
                      Ver principal
                    </a>
                    <a href={certification.href} download class="inline-flex rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-slate-200 transition hover:-translate-y-0.5 hover:border-cyan-300/25 hover:text-cyan-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Descargar PDF del certificado principal ${certification.title}`}>
                      Descargar
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <details class="group mt-5 rounded-3xl border border-white/10 bg-slate-950/30 p-4 transition open:border-cyan-300/25 open:bg-slate-950/45">
            <summary class="cursor-pointer list-none text-sm font-semibold text-white marker:hidden">
              <span class="inline-flex w-full items-center justify-between gap-3">
                <span>Ver certificados por curso</span>
                <span class="inline-flex items-center gap-2 rounded-full bg-white/[0.06] px-3 py-1 text-xs text-slate-300">
                  {program.courseCertificates.length} cursos <span class="transition group-open:rotate-180" aria-hidden="true">↓</span>
                </span>
              </span>
            </summary>
            <div class="mt-4 grid gap-3">
              {program.courseCertificates.map((certification) => (
                <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4">
                  <h4 class="font-semibold text-white">{certification.title}</h4>
                  <p class="mt-2 text-sm leading-6 text-slate-300">{certification.focus}</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    <a href={certification.href} target="_blank" rel="noreferrer" class="inline-flex rounded-full border border-cyan-300/20 bg-cyan-300/5 px-3 py-1.5 text-xs font-semibold text-cyan-100 transition hover:-translate-y-0.5 hover:bg-cyan-300/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Abrir certificado de curso ${certification.title} en PDF`}>
                      Ver PDF
                    </a>
                    <a href={certification.href} download class="inline-flex rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs font-semibold text-slate-200 transition hover:-translate-y-0.5 hover:border-cyan-300/25 hover:text-cyan-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Descargar PDF del certificado de curso ${certification.title}`}>
                      Descargar
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </details>
        </article>
      ))}
    </div>
  </div>
</section>
