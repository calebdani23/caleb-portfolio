---
import type { CertificationProgram } from "../data/certifications";
import SectionHeader from "./SectionHeader.astro";

type Props = {
  certifications: CertificationProgram[];
};

const { certifications } = Astro.props;
---

<section id="certificados" class="px-5 py-20 sm:px-8 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <SectionHeader
      eyebrow="Certificados"
      title="Aprendizaje autodidacta con evidencia descargable."
      description="Estos certificados refuerzan mi camino de aprendizaje independiente: soporte técnico, redes, sistemas, seguridad, Git/GitHub y hábitos de autodesarrollo."
    />

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {certifications.map((program) => (
        <article class="section-reveal surface-elevated p-5 transition duration-300 hover:-translate-y-1 hover:border-cyan-300/25 sm:p-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-cyan-300">{program.issuer}</p>
              <h3 class="mt-3 text-2xl font-semibold leading-8 text-white">{program.title}</h3>
            </div>
            <span class="evidence-label w-fit rounded-full px-3 py-1 text-xs font-semibold">
              {program.mainCertificates.length + program.courseCertificates.length} PDF{program.mainCertificates.length + program.courseCertificates.length > 1 ? "s" : ""}
            </span>
          </div>
          <p class="mt-4 leading-7 text-slate-300">{program.summary}</p>

          <div class="media-frame mt-6 rounded-3xl p-3 sm:p-4">
            <div class="mb-3 flex items-center justify-between gap-3 px-1">
              <p class="text-sm font-semibold text-cyan-100">Evidencia principal del programa</p>
              <span class="text-xs text-slate-500">Preview renderizado</span>
            </div>
            <div class="grid gap-4">
              {program.mainCertificates.map((certification) => (
                <div class="rounded-[1.45rem] border border-white/10 bg-slate-950/35 p-2.5 sm:p-3">
                  <figure class="certificate-preview-frame relative overflow-hidden rounded-[1.2rem] border border-cyan-300/15 bg-slate-950/70 shadow-inner shadow-cyan-950/30">
                    {certification.previewImage ? (
                      <img
                        src={certification.previewImage}
                        alt={certification.previewAlt ?? `Vista previa renderizada del certificado ${certification.title}`}
                        loading="lazy"
                        decoding="async"
                        class="aspect-[1801/1391] w-full bg-white object-contain"
                      />
                    ) : (
                      <a
                        href={certification.href}
                        target="_blank"
                        rel="noreferrer"
                        class="flex aspect-[1801/1391] w-full items-center justify-center p-6 text-center text-sm font-semibold text-cyan-100"
                      >
                        Abrir vista previa del PDF
                      </a>
                    )}
                    <span class="pointer-events-none absolute left-3 top-3 rounded-full border border-cyan-300/25 bg-slate-950/75 px-2.5 py-1 text-[0.62rem] font-bold uppercase tracking-[0.18em] text-cyan-100 backdrop-blur">
                      Imagen del PDF
                    </span>
                  </figure>

                  <div class="px-2 pb-2 pt-5 sm:px-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300/80">Certificado principal</p>
                    <h4 class="mt-2 text-xl font-semibold text-white">{certification.title}</h4>
                    <p class="mt-3 text-sm leading-6 text-slate-300">{certification.focus}</p>
                    <div class="mt-5 flex flex-wrap gap-2">
                      <a href={certification.href} target="_blank" rel="noreferrer" class="btn-primary px-4 py-2 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Abrir certificado principal ${certification.title} en PDF`}>
                        Ver principal
                      </a>
                      <a href={certification.href} download class="btn-secondary px-4 py-2 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Descargar PDF del certificado principal ${certification.title}`}>
                        Descargar
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <details class="group mt-5 rounded-3xl border border-white/10 bg-slate-950/30 p-4 transition open:border-cyan-300/25 open:bg-slate-950/45">
            <summary class="cursor-pointer list-none text-sm font-semibold text-white marker:hidden">
              <span class="inline-flex w-full items-center justify-between gap-3">
                <span>Ver certificados por curso</span>
                <span class="inline-flex items-center gap-2 rounded-full bg-white/[0.06] px-3 py-1 text-xs text-slate-300">
                  {program.courseCertificates.length} cursos <span class="transition group-open:rotate-180" aria-hidden="true">↓</span>
                </span>
              </span>
            </summary>
            <div class="mt-4 grid gap-3">
              {program.courseCertificates.map((certification) => (
                <div class="rounded-2xl border border-white/10 bg-white/[0.025] p-4">
                  <h4 class="font-semibold text-white">{certification.title}</h4>
                  <p class="mt-2 text-sm leading-6 text-slate-300">{certification.focus}</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    <a href={certification.href} target="_blank" rel="noreferrer" class="link-cta border border-cyan-300/20 bg-cyan-300/5 px-3 py-1.5 text-xs focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Abrir certificado de curso ${certification.title} en PDF`}>
                      Ver PDF
                    </a>
                    <a href={certification.href} download class="btn-secondary px-3 py-1.5 text-xs focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Descargar PDF del certificado de curso ${certification.title}`}>
                      Descargar
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </details>
        </article>
      ))}
    </div>
  </div>
</section>
