---
import type { CertificationProgram, RecognitionItem } from "../data/certifications";
import SectionHeader from "./SectionHeader.astro";
import { withBase } from "../utils/paths";

type Props = {
  certifications: CertificationProgram[];
  recognitions: RecognitionItem[];
};

const { certifications, recognitions } = Astro.props;
---

<section id="certificados" class="px-5 py-20 sm:px-8 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <SectionHeader
      eyebrow="Certificates & recognitions"
      title="Self-driven learning, service mindset and real-world discipline."
      description="A selection of certificates and personal milestones that connect technical growth with adaptability, teamwork and initiative."
    />

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {certifications.map((program) => (
        <article class="section-reveal surface-elevated p-5 transition duration-300 hover:-translate-y-1 hover:border-cyan-300/25 sm:p-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-cyan-300">{program.issuer}</p>
              <h3 class="mt-3 text-2xl font-semibold leading-8 text-white">{program.title}</h3>
            </div>
            <span class="evidence-label w-fit rounded-full px-3 py-1 text-xs font-semibold">
               {program.mainCertificates.length + program.courseCertificates.length} public PDF{program.mainCertificates.length + program.courseCertificates.length > 1 ? "s" : ""}
            </span>
          </div>
          <p class="mt-4 leading-7 text-slate-300">{program.summary}</p>

          <div class="media-frame mt-6 rounded-3xl p-3 sm:p-4">
            <div class="mb-3 flex items-center justify-between gap-3 px-1">
              <p class="text-sm font-semibold text-cyan-100">Main program evidence</p>
              <span class="text-xs text-slate-500">Rendered preview</span>
            </div>
            <div class="grid gap-4">
              {program.mainCertificates.map((certification) => (
                <div class="rounded-[1.45rem] border border-white/10 bg-slate-950/35 p-2.5 sm:p-3">
                  <figure class="certificate-preview-frame relative overflow-hidden rounded-[1.2rem] border border-cyan-300/15 bg-slate-950/70 shadow-inner shadow-cyan-950/30">
                    {certification.previewImage ? (
                      <img
                        src={withBase(certification.previewImage)}
                        alt={certification.previewAlt ?? `Vista previa renderizada del certificado ${certification.title}`}
                        loading="lazy"
                        decoding="async"
                        class="aspect-[1801/1391] w-full bg-white object-contain"
                      />
                    ) : (
                      <a
                        href={withBase(certification.href)}
                        target="_blank"
                        rel="noreferrer"
                        class="flex aspect-[1801/1391] w-full items-center justify-center p-6 text-center text-sm font-semibold text-cyan-100"
                      >
                         Open PDF preview
                      </a>
                    )}
                    <span class="pointer-events-none absolute left-3 top-3 rounded-full border border-cyan-300/25 bg-slate-950/75 px-2.5 py-1 text-[0.62rem] font-bold uppercase tracking-[0.18em] text-cyan-100 backdrop-blur">
                       PDF image
                    </span>
                  </figure>

                  <div class="px-2 pb-2 pt-5 sm:px-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300/80">Main certificate</p>
                    <h4 class="mt-2 text-xl font-semibold text-white">{certification.title}</h4>
                    <p class="mt-3 text-sm leading-6 text-slate-300">{certification.focus}</p>
                    <div class="mt-5 flex flex-wrap gap-2">
                      <a href={withBase(certification.href)} target="_blank" rel="noreferrer" class="btn-primary px-4 py-2 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Open main certificate PDF for ${certification.title}`}>
                        View main
                      </a>
                       <a href={withBase(certification.href)} download class="btn-secondary px-4 py-2 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Download main certificate PDF ${certification.title}`}>
                        Download
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <details class="group mt-5 rounded-3xl border border-white/10 bg-slate-950/30 p-4 transition open:border-cyan-300/25 open:bg-slate-950/45">
            <summary class="cursor-pointer list-none text-sm font-semibold text-white marker:hidden">
              <span class="inline-flex w-full items-center justify-between gap-3">
                <span>View course certificates</span>
                <span class="inline-flex items-center gap-2 rounded-full bg-white/[0.06] px-3 py-1 text-xs text-slate-300">
                  {program.courseCertificates.length} courses <span class="transition group-open:rotate-180" aria-hidden="true">↓</span>
                </span>
              </span>
            </summary>
            <div class="mt-4 grid gap-3">
              {program.courseCertificates.map((certification) => (
                <div class="rounded-2xl border border-white/10 bg-white/[0.025] p-4">
                  <h4 class="font-semibold text-white">{certification.title}</h4>
                  <p class="mt-2 text-sm leading-6 text-slate-300">{certification.focus}</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    <a href={withBase(certification.href)} target="_blank" rel="noreferrer" class="link-cta border border-cyan-300/20 bg-cyan-300/5 px-3 py-1.5 text-xs focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Open course certificate PDF for ${certification.title}`}>
                      View PDF
                    </a>
                    <a href={withBase(certification.href)} download class="btn-secondary px-3 py-1.5 text-xs focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label={`Download course certificate PDF ${certification.title}`}>
                      Download
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </details>
        </article>
      ))}
    </div>

    <div class="mt-14 border-t border-white/10 pt-10">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Global / personal recognitions</p>
        <h3 class="mt-3 text-3xl font-semibold tracking-tight text-white">Experiences that shaped how I work with people and pressure.</h3>
        <p class="mt-4 leading-7 text-slate-300">These cards strengthen the broader story — service, independence and competitive discipline — through moments that shaped my perspective beyond code.</p>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {recognitions.map((recognition) => (
          <article class="section-reveal surface-soft p-5 transition hover:-translate-y-1 hover:border-cyan-300/25 hover:bg-white/[0.06]">
            {recognition.image && (
              <img src={withBase(recognition.image)} alt={recognition.imageAlt ?? recognition.title} loading="lazy" decoding="async" class="mb-5 aspect-[4/3] w-full rounded-2xl border border-white/10 bg-slate-950 object-cover" />
            )}
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">{recognition.context}</p>
            <h4 class="mt-3 text-xl font-semibold text-white">{recognition.title}</h4>
            <p class="mt-3 text-sm leading-6 text-slate-300">{recognition.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
