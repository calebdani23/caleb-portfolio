---
import type { StackGroup } from "../data/stack";

type Props = {
  groups: StackGroup[];
};

const { groups } = Astro.props;
---

<div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
  {groups.map((group) => (
    <article class="section-reveal rounded-3xl border border-white/10 bg-white/[0.04] p-6 transition hover:-translate-y-1 hover:border-cyan-300/25 hover:bg-white/[0.065]">
      <h3 class="text-xl font-semibold text-white">{group.title}</h3>
      <p class="mt-3 min-h-14 leading-7 text-slate-300">{group.description}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {group.items.map((item) => (
          <span class="rounded-full border border-white/10 bg-slate-950/40 px-3 py-1.5 text-sm text-slate-200">{item}</span>
        ))}
      </div>
    </article>
  ))}
</div>
