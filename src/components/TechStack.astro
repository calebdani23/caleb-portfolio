---
import type { StackGroup } from "../data/stack";

type Props = {
  groups: StackGroup[];
};

const { groups } = Astro.props;
const toneClasses = {
  frontend: "border-sky-300/20 bg-sky-300/6 text-sky-100",
  backend: "border-emerald-300/20 bg-emerald-300/6 text-emerald-100",
  ai: "border-violet-300/20 bg-violet-300/7 text-violet-100",
  travel: "border-amber-200/20 bg-amber-200/7 text-amber-100",
  infra: "border-slate-300/20 bg-slate-400/7 text-slate-100",
  ux: "border-yellow-100/20 bg-yellow-100/7 text-yellow-50",
};
---

<div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
  {groups.map((group) => (
    <article class:list={["section-reveal surface-soft p-6 transition hover:-translate-y-1 hover:bg-white/[0.065]", toneClasses[group.tone]]}>
      <div class="flex items-center gap-3">
        <span class="grid size-11 place-items-center rounded-2xl border border-current/20 bg-white/[0.05] text-xl" aria-hidden="true">{group.icon}</span>
        <h3 class="text-xl font-semibold text-white">{group.title}</h3>
      </div>
      <p class="mt-3 min-h-14 leading-7 text-slate-300">{group.description}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {group.items.map((item) => (
          <span class="rounded-full border border-current/15 bg-slate-950/35 px-3 py-1.5 text-sm text-slate-100">{item}</span>
        ))}
      </div>
    </article>
  ))}
</div>
