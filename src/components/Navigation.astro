---
const isHome = Astro.url.pathname === "/";
const sectionHref = (hash: string) => (isHome ? hash : `/${hash}`);
const links = [
  { label: "Sobre mí", href: sectionHref("#sobre-mi") },
  { label: "Proyectos", href: sectionHref("#proyectos") },
  { label: "Zalmar", href: sectionHref("#zalmar-travel") },
  { label: "Camino", href: sectionHref("#journey") },
  { label: "Certificados", href: sectionHref("#certificados") },
  { label: "Fútbol", href: sectionHref("#trayectoria-deportiva") },
  { label: "Stack", href: sectionHref("#stack") },
  { label: "Contacto", href: sectionHref("#contacto") },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-cyan-300/10 bg-[#06141b]/86 shadow-2xl shadow-black/20 backdrop-blur-2xl">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-300/50 to-transparent"></div>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-8 lg:px-10" aria-label="Principal">
    <a href={sectionHref("#inicio")} class="group inline-flex items-center gap-3 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label="Ir al inicio">
      <span class="grid size-9 place-items-center rounded-2xl border border-cyan-300/30 bg-cyan-300/10 text-sm font-bold text-cyan-200 shadow-lg shadow-cyan-950/30 transition duration-300 group-hover:scale-105 group-hover:border-cyan-200/60 group-hover:shadow-cyan-500/10">
        CP
      </span>
      <span class="hidden text-sm font-semibold text-white sm:block">Caleb Perez</span>
    </a>

    <div class="hidden items-center gap-1 rounded-full border border-white/10 bg-white/[0.03] p-1 lg:flex">
      {links.map((link) => (
        <a href={link.href} class="rounded-full px-4 py-2 text-sm text-slate-300 transition duration-300 hover:bg-white/10 hover:text-white hover:shadow-inner hover:shadow-cyan-300/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300">
          {link.label}
        </a>
      ))}
    </div>

    <a href="mailto:calebdani@icloud.com" class="rounded-full bg-cyan-300 px-4 py-2 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-950/30 transition hover:-translate-y-0.5 hover:bg-cyan-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300">
      Hablemos
    </a>
  </nav>

  <div class="border-t border-white/5 px-5 pb-3 lg:hidden">
    <div class="flex gap-2 overflow-x-auto pt-3 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="Navegación móvil">
      {links.map((link) => (
        <a href={link.href} class="shrink-0 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-xs font-medium text-slate-300 transition hover:border-cyan-300/30 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>
<div class="h-[7.25rem] lg:h-[4.5rem]" aria-hidden="true"></div>
