---
import type { WorkStep } from "../data/workMethod";

type Props = {
  steps: WorkStep[];
};

const { steps } = Astro.props;
---

<div class="mt-12 grid gap-4 lg:grid-cols-3">
  {steps.map((step, index) => (
    <article class="section-reveal surface-soft relative overflow-hidden p-6 transition hover:-translate-y-1 hover:border-cyan-300/25 hover:bg-white/[0.065]">
      <div class="pointer-events-none absolute right-5 top-4 text-6xl font-black leading-none text-white/[0.035]">{String(index + 1).padStart(2, "0")}</div>
      <div class="flex items-center gap-3">
        <span class="grid size-10 place-items-center rounded-2xl border border-cyan-300/20 bg-cyan-300/10 text-cyan-100" aria-hidden="true">{step.icon}</span>
        <span class="text-sm font-semibold text-cyan-300">{String(index + 1).padStart(2, "0")}</span>
      </div>
      <h3 class="mt-4 text-xl font-semibold text-white">{step.title}</h3>
      <p class="mt-3 leading-7 text-slate-300">{step.description}</p>
      <p class="mt-5 rounded-2xl border border-white/10 bg-slate-950/35 p-3 text-sm font-semibold text-cyan-100">{step.outcome}</p>
    </article>
  ))}
</div>
