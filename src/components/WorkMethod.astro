---
import type { WorkStep } from "../data/workMethod";

type Props = {
  steps: WorkStep[];
};

const { steps } = Astro.props;
---

<div class="mt-12 grid gap-4 lg:grid-cols-3">
  {steps.map((step, index) => (
    <article class="section-reveal rounded-3xl border border-white/10 bg-white/[0.04] p-6 transition hover:-translate-y-1 hover:bg-white/[0.065]">
      <span class="text-sm font-semibold text-cyan-300">{String(index + 1).padStart(2, "0")}</span>
      <h3 class="mt-4 text-xl font-semibold text-white">{step.title}</h3>
      <p class="mt-3 leading-7 text-slate-300">{step.description}</p>
    </article>
  ))}
</div>
