---
import type { Project } from "../data/projects";
import { withBase } from "../utils/paths";

type Props = {
  project: Project;
};

const { project } = Astro.props;
const featuredImage = project.featuredImage ?? project.previewImage;
---

<article id="zalmar-travel" class="premium-card relative overflow-hidden p-6 sm:p-8 lg:p-10 scroll-mt-24">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_20%_20%,rgba(34,211,238,0.18),transparent_35%),radial-gradient(circle_at_85%_80%,rgba(250,204,21,0.08),transparent_34%)]"></div>
  <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div class="section-reveal">
      <div class="flex flex-wrap items-center gap-3">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Main project</p>
        <span class="rounded-full border border-amber-200/20 bg-amber-200/10 px-3 py-1 text-xs font-semibold text-amber-100">In development</span>
      </div>
      {project.brandImage && (
        <div class="mt-5 inline-flex rounded-3xl border border-white/10 bg-white/[0.04] p-3 shadow-lg shadow-slate-950/20">
          <img src={withBase(project.brandImage)} alt={project.brandAlt ?? `${project.title} brand mark`} loading="lazy" decoding="async" class="h-12 w-12 object-contain" />
        </div>
      )}
      <h2 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">{project.title}</h2>
      <p class="mt-6 text-lg leading-8 text-slate-300">{project.description}</p>

      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {project.metrics?.map((metric) => (
          <div class="rounded-3xl border border-white/10 bg-white/[0.05] p-4">
            <p class="text-2xl font-semibold text-white">{metric.value}</p>
            <p class="mt-1 text-sm text-slate-400">{metric.label}</p>
          </div>
        ))}
      </div>
      {project.href && (
        <a href={withBase(project.href)} class="mt-8 inline-flex rounded-full bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-950/30 transition hover:-translate-y-1 hover:bg-cyan-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300">
          View full case study
        </a>
      )}
      <span class="mt-3 inline-flex rounded-full border border-white/10 bg-white/[0.04] px-5 py-3 text-sm font-semibold text-slate-300">
        Pitch deck available on request
      </span>
    </div>

    <div class="rounded-[1.75rem] border border-cyan-300/15 bg-slate-950/70 p-5 shadow-2xl shadow-cyan-950/20 ring-1 ring-white/5 sm:p-6">
      <div class="flex flex-wrap items-center justify-between gap-4 border-b border-white/10 pb-4">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-cyan-200/80">Operating console</p>
          <p class="mt-2 text-2xl font-semibold text-white">Progress</p>
        </div>
        <span class="rounded-full bg-emerald-300/10 px-3 py-1 text-xs font-semibold text-emerald-200">under construction</span>
      </div>

      <p class="mt-4 text-sm leading-6 text-slate-300">
        Search opens the journey; plan, workspace, quote, booking and reservation states carry the product value.
      </p>

      <div class="mt-5 grid gap-3 sm:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
          <p class="text-3xl font-semibold text-white">Plan</p>
          <p class="mt-2 text-sm text-slate-400">Workspace · quotes · readiness</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
          <p class="text-3xl font-semibold text-white">Trust</p>
          <p class="mt-2 text-sm text-slate-400">Providers · payment · reservation</p>
        </div>
      </div>

      <div class="mt-4 rounded-2xl border border-white/10 bg-white/[0.04] p-4">
        <div class="mb-3 flex items-center justify-between text-xs text-slate-400">
          <span>Search</span><span>Plan</span><span>Quote</span><span>Booking</span>
        </div>
        <div class="h-2 rounded-full bg-white/10">
          <div class="h-2 w-4/5 rounded-full bg-gradient-to-r from-cyan-300 to-sky-400"></div>
        </div>
      </div>
    </div>

    <div class="section-reveal grid gap-5 lg:col-span-2">
      <div class="surface-elevated p-4 sm:p-5 lg:p-6">
        <div class="grid gap-5 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.25fr)] lg:items-start">
          {featuredImage && (
            <figure class="browser-frame">
              <img
                src={withBase(featuredImage)}
                alt={project.previewAlt ?? `Captura de ${project.title}`}
                loading="lazy"
                decoding="async"
                class="aspect-[16/10] w-full bg-slate-950 object-cover"
                style={`object-fit: ${project.previewObjectFit ?? "cover"}; object-position: ${project.previewObjectPosition ?? "top center"};`}
              />
              <figcaption class="media-caption flex flex-col gap-2 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
                 <span>Spanish-language MVP evidence used to validate the plan-first booking journey.</span>
                <span class="w-fit rounded-full bg-cyan-300/10 px-3 py-1 text-xs font-semibold text-cyan-100">{project.visualLabel}</span>
              </figcaption>
            </figure>
          )}

          <div class="grid gap-4">
            <div class="flex flex-col gap-3 border-b border-white/10 pb-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                 <p class="text-sm font-semibold text-white">Master-plan workspace</p>
                 <p class="mt-1 text-xs text-slate-400">Search · Plan · Workspace · Quote · Booking · Reservation</p>
              </div>
               <span class="w-fit rounded-full bg-cyan-300 px-3 py-1 text-xs font-bold text-slate-950">AI-assisted</span>
            </div>

            <div class="grid gap-3 md:grid-cols-2">
              {project.highlights?.map((highlight, index) => (
                <div class="flex gap-4 rounded-2xl border border-white/10 bg-white/[0.04] p-4 transition hover:border-cyan-300/20">
                  <span class="grid size-8 shrink-0 place-items-center rounded-full bg-cyan-300/15 text-sm font-semibold text-cyan-200">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <p class="text-sm leading-6 text-slate-300">{highlight}</p>
                </div>
              ))}
            </div>

            <div class="rounded-2xl border border-amber-200/10 bg-amber-200/5 p-4">
              <p class="text-sm font-medium text-amber-100">Current state</p>
              <p class="mt-2 text-sm leading-6 text-slate-300">
                In development as the central product of the portfolio; the case study is careful to show MVP evidence without exposing internal implementation references.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</article>
