---
import type { SportsHighlight } from "../data/sports";
import SectionHeader from "./SectionHeader.astro";

type Props = {
  highlights: SportsHighlight[];
};

const { highlights } = Astro.props;
---

<section id="trayectoria-deportiva" class="px-5 py-20 sm:px-8 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <SectionHeader
      eyebrow="Trayectoria deportiva"
      title="Fútbol como escuela de disciplina, presión y equipo."
      description="Esta parte no compite con mi perfil técnico: lo complementa. El deporte me enseñó constancia, competir con presión real y trabajar dentro de sistemas donde el resultado depende del grupo."
    />

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {highlights.map((highlight, highlightIndex) => (
        <article class="premium-card section-reveal overflow-hidden p-4 transition duration-300 hover:-translate-y-1 hover:border-cyan-300/20 sm:p-5">
          <div class="mb-3 flex items-center justify-between gap-3 px-1">
            <span class="rounded-full bg-cyan-300/10 px-3 py-1 text-xs font-semibold text-cyan-100">{highlight.videos.length} video{highlight.videos.length > 1 ? "s" : ""} curado{highlight.videos.length > 1 ? "s" : ""}</span>
            <span class="text-xs text-slate-500">Reproducir bajo demanda</span>
          </div>
          <div class="relative">
            <div id={`sports-carousel-${highlightIndex}`} class="sports-carousel flex snap-x snap-mandatory gap-3 overflow-x-auto scroll-smooth rounded-[1.5rem]" aria-label={`Videos de ${highlight.title}`} tabindex="0">
              {highlight.videos.map((video, videoIndex) => (
                <figure class="video-frame min-w-full snap-center p-2">
                  <video controls preload="metadata" playsinline poster={video.poster} class="aspect-video w-full rounded-[1.1rem] bg-slate-950 object-cover" aria-label={`${video.label} de ${highlight.title}`}>
                    <source src={video.src} type="video/mp4" />
                    Tu navegador no soporta video HTML5.
                  </video>
                  <figcaption class="media-caption flex flex-col gap-1 px-2 pt-3 sm:flex-row sm:items-center sm:justify-between">
                    <span><span class="font-semibold text-slate-200">{video.label}:</span> {video.note}</span>
                    <span class="text-cyan-300/80">{videoIndex + 1}/{highlight.videos.length}</span>
                  </figcaption>
                </figure>
              ))}
            </div>

            <div class="mt-4 flex items-center justify-between gap-3">
              <button type="button" class="sports-carousel-button btn-secondary px-4 py-2 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" data-carousel-target={`sports-carousel-${highlightIndex}`} data-carousel-direction="prev" aria-label={`Ver video anterior de ${highlight.title}`}>
                ← Anterior
              </button>
              <p class="text-center text-xs text-slate-500">Desliza o usa las flechas para cambiar de clip.</p>
              <button type="button" class="sports-carousel-button btn-secondary px-4 py-2 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" data-carousel-target={`sports-carousel-${highlightIndex}`} data-carousel-direction="next" aria-label={`Ver siguiente video de ${highlight.title}`}>
                Siguiente →
              </button>
            </div>
          </div>
          <div class="p-2 pt-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">{highlight.context}</p>
            <h3 class="mt-3 text-2xl font-semibold text-white">{highlight.title}</h3>
            <p class="mt-4 leading-7 text-slate-300">{highlight.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>(".sports-carousel-button").forEach((button) => {
    button.addEventListener("click", () => {
      const targetId = button.dataset.carouselTarget;
      const direction = button.dataset.carouselDirection === "prev" ? -1 : 1;
      if (!targetId) return;

      const carousel = document.getElementById(targetId);
      if (!carousel) return;

      carousel.scrollBy({ left: carousel.clientWidth * direction, behavior: "smooth" });
    });
  });
</script>
