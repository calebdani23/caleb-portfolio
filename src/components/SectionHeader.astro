---
type Props = {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
};

const { eyebrow, title, description, align = "left" } = Astro.props;
const isCentered = align === "center";
---

<div class:list={["section-reveal", isCentered ? "mx-auto max-w-3xl text-center" : "max-w-3xl"]}>
  <p class="text-xs font-semibold uppercase tracking-[0.35em] text-cyan-300/90">{eyebrow}</p>
  <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl">{title}</h2>
  {
    description && (
      <p class="mt-5 text-base leading-8 text-slate-300 sm:text-lg">{description}</p>
    )
  }
</div>
