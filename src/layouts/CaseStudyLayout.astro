---
import Footer from "../components/Footer.astro";
import Navigation from "../components/Navigation.astro";
import BaseLayout from "./BaseLayout.astro";
import type { CaseStudy } from "../data/caseStudies";
import { withBase } from "../utils/paths";

type Props = {
  caseStudy: CaseStudy;
  previous?: CaseStudy;
  next?: CaseStudy;
};

const { caseStudy, previous, next } = Astro.props;
const title = `${caseStudy.title} — Caleb Perez case study`;
const isZalmarTravel = caseStudy.slug === "zalmar-travel";
const externalProjectLinks: Record<string, string> = {
  "ai-agent-observability-dashboard": "https://calebdani23.github.io/ai-agent-observability-dashboard/",
  "ai-codebase-explainer": "https://calebdani23.github.io/ai-codebase-explainer/",
};
const liveProjectUrl = externalProjectLinks[caseStudy.slug];
const usesIntegratedArchitectureBlock = [
  "ai-agent-observability-dashboard",
  "ai-codebase-explainer",
  "family-home-server-private-cloud",
].includes(caseStudy.slug);
const zalmarLightLogo = "/images/projects/zalmar-travel/zalmar-logo-claro.svg";
const primaryVisual = usesIntegratedArchitectureBlock ? caseStudy.gallery?.[0] : undefined;
const architectureVisual = usesIntegratedArchitectureBlock ? caseStudy.gallery?.[1] : undefined;
const remainingGallery = usesIntegratedArchitectureBlock ? caseStudy.gallery?.slice(2) : caseStudy.gallery;
const sections = [
  caseStudy.sections.problem,
  caseStudy.sections.solution,
  ...(usesIntegratedArchitectureBlock ? [] : [caseStudy.sections.architecture]),
  caseStudy.sections.challenges,
  caseStudy.sections.decisions,
  caseStudy.sections.result,
  caseStudy.sections.learnings,
  caseStudy.sections.nextSteps,
];
---

<BaseLayout title={title} description={caseStudy.summary} canonical={`/proyectos/${caseStudy.slug}`}>
  <Navigation />

  <article class:list={["px-5 py-16 sm:px-8 sm:py-20 lg:px-10", isZalmarTravel && "zalmar-case-study"]}>
    <div class="mx-auto max-w-7xl">
      <a href={withBase("/#proyectos")} class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:-translate-y-0.5 hover:border-cyan-300/30 hover:bg-white/[0.07] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300">
        <span aria-hidden="true">←</span> Back to projects
      </a>

      <header class="mt-10 grid gap-10 lg:grid-cols-[1fr_0.78fr] lg:items-end">
        <div class="section-reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">{caseStudy.eyebrow}</p>
          {caseStudy.brandImage && (
            <div class:list={["mt-6 inline-flex rounded-3xl border border-white/10 bg-white/[0.04] p-3 shadow-lg shadow-slate-950/20", isZalmarTravel && "zalmar-logo-chip"]}>
              <img src={withBase(caseStudy.brandImage)} alt={caseStudy.brandAlt ?? `${caseStudy.title} brand mark`} loading="lazy" decoding="async" class:list={[isZalmarTravel ? "h-16 w-16" : "h-14 w-14", "object-contain"]} />
            </div>
          )}
          <h1 class="mt-5 max-w-5xl text-5xl font-semibold tracking-[-0.03em] text-white sm:text-7xl">
            {caseStudy.title}
          </h1>
          <p class="mt-7 max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl">{caseStudy.description}</p>
        </div>

        <aside class="premium-card section-reveal p-6" aria-label="Case study summary">
          <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
            <p class="text-sm font-semibold text-white">Status</p>
            <span class="rounded-full bg-cyan-300 px-3 py-1 text-xs font-bold text-slate-950">{caseStudy.status}</span>
          </div>
          <p class="mt-5 text-sm leading-6 text-slate-300">{caseStudy.summary}</p>
          {liveProjectUrl && (
            <a
              href={liveProjectUrl}
              target="_blank"
              rel="noreferrer"
              class="btn-primary mt-6 inline-flex items-center gap-2 px-5 py-3 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300"
              aria-label={`Open live page for ${caseStudy.title}`}
            >
              Open live page <span aria-hidden="true">↗</span>
            </a>
          )}
          <div class="mt-6 flex flex-wrap gap-2">
            {caseStudy.highlights.map((highlight) => (
              <span class="rounded-full border border-white/10 bg-white/[0.05] px-3 py-1 text-xs text-slate-200">{highlight}</span>
            ))}
          </div>
        </aside>
      </header>

      {isZalmarTravel && (
        <section class="zalmar-brand-panel section-reveal mt-12 overflow-hidden p-6 sm:p-8" aria-labelledby="zalmar-brand-case-study">
          <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
            <div class="rounded-[2rem] border border-[#c39f55]/25 bg-[#06141b]/70 p-6 shadow-2xl shadow-slate-950/25">
              <img src={withBase(zalmarLightLogo)} alt="Zalmar Travel wordmark" loading="lazy" decoding="async" class="mx-auto h-32 w-32 object-contain sm:h-40 sm:w-40" />
              <div class="mt-5 flex justify-center gap-2" aria-hidden="true">
                <span class="h-1.5 w-10 rounded-full bg-[#c39f55]"></span>
                <span class="h-1.5 w-10 rounded-full bg-cyan-300/80"></span>
                <span class="h-1.5 w-10 rounded-full bg-white/70"></span>
              </div>
            </div>

            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#f3d38b]">Branded product case study</p>
              <h2 id="zalmar-brand-case-study" class="mt-3 max-w-3xl text-3xl font-semibold tracking-tight text-white sm:text-4xl">A travel workspace shaped around trust, readiness and reservation control.</h2>
              <p class="mt-5 max-w-3xl leading-8 text-slate-300">The product identity pairs a grounded dark travel-tech interface with warm gold and cyan accents, giving the case study a dedicated brand frame without distracting from the UX and orchestration work.</p>
              <div class="mt-6 grid gap-3 sm:grid-cols-3">
                {[
                  "Plan-first brand story",
                  "Provider-aware booking UX",
                  "Spanish MVP evidence",
                ].map((item) => (
                  <span class="rounded-2xl border border-[#c39f55]/20 bg-[#c39f55]/10 px-4 py-3 text-sm font-semibold text-[#fff4cf]">{item}</span>
                ))}
              </div>
            </div>
          </div>
        </section>
      )}

      <section class="mt-12 grid gap-5 lg:grid-cols-[0.74fr_1.26fr]" aria-labelledby="role-stack">
        <div class="surface-elevated p-6">
          <h2 id="role-stack" class="text-xl font-semibold text-white">My role</h2>
          <p class="mt-4 leading-7 text-slate-300">{caseStudy.role}</p>
        </div>
        <div class="surface-soft p-6">
          <h2 class="text-xl font-semibold text-white">Stack and concepts</h2>
          <div class="mt-5 flex flex-wrap gap-2">
            {caseStudy.stack.map((item) => (
              <span class="rounded-full bg-cyan-300/10 px-3 py-1.5 text-sm text-cyan-100">{item}</span>
            ))}
          </div>
        </div>
      </section>

      {!usesIntegratedArchitectureBlock && (
        <section class="surface-outline mt-12 p-5 sm:p-6" aria-labelledby="case-flow">
          <h2 id="case-flow" class="text-2xl font-semibold text-white">Flow architecture</h2>
          <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-7">
            {caseStudy.flow.map((step, index) => (
              <div class="rounded-3xl border border-white/10 bg-slate-950/40 p-4">
                <span class="text-xs font-semibold text-cyan-300">{String(index + 1).padStart(2, "0")}</span>
                <p class="mt-3 text-sm font-semibold text-white">{step}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {primaryVisual && (
        <section class="mt-12" aria-labelledby="primary-evidence">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Primary evidence</p>
            <h2 id="primary-evidence" class="mt-3 text-3xl font-semibold tracking-tight text-white">Public-facing product view</h2>
          </div>

          <figure class="browser-frame mt-8 overflow-hidden border-cyan-300/20">
            <img src={withBase(primaryVisual.src)} alt={primaryVisual.alt} loading="lazy" decoding="async" class="aspect-[16/8] w-full bg-slate-950 object-cover object-top" />
            <figcaption class="media-caption px-4 py-4">{primaryVisual.caption}</figcaption>
          </figure>
        </section>
      )}

      {usesIntegratedArchitectureBlock && architectureVisual && (
        <section class="surface-outline mt-12 p-5 sm:p-6" aria-labelledby="architecture-system-view">
          <div class="grid gap-8 lg:grid-cols-[1.12fr_0.88fr] lg:items-start">
            <div>
              <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Architecture view</p>
                <button
                  type="button"
                  class="architecture-lightbox-trigger inline-flex items-center justify-center gap-2 self-start rounded-full border border-cyan-300/25 bg-cyan-300/10 px-4 py-2 text-sm font-bold text-cyan-50 transition hover:-translate-y-0.5 hover:border-cyan-200/50 hover:bg-cyan-300/16 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300 sm:self-auto"
                  data-lightbox-target={`architecture-lightbox-${caseStudy.slug}`}
                  aria-haspopup="dialog"
                  aria-controls={`architecture-lightbox-${caseStudy.slug}`}
                >
                  <span aria-hidden="true">⤢</span>
                  Expand view
                </button>
              </div>
              <figure class="browser-frame group mt-5 overflow-hidden border-white/12 bg-slate-950/70 transition duration-300 hover:-translate-y-1 hover:border-cyan-300/30 hover:shadow-cyan-950/30">
                <button
                  type="button"
                  class="architecture-lightbox-trigger relative block w-full cursor-zoom-in overflow-hidden bg-slate-950 text-left focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-6px] focus-visible:outline-cyan-300"
                  data-lightbox-target={`architecture-lightbox-${caseStudy.slug}`}
                  aria-haspopup="dialog"
                  aria-controls={`architecture-lightbox-${caseStudy.slug}`}
                  aria-label={`Expand architecture view: ${architectureVisual.alt}`}
                >
                  <img src={withBase(architectureVisual.src)} alt={architectureVisual.alt} loading="lazy" decoding="async" class="aspect-[16/10] w-full object-contain object-center bg-slate-950 p-4 transition duration-300 group-hover:scale-[1.035] sm:p-6" />
                  <span class="pointer-events-none absolute right-4 top-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-slate-950/80 px-3 py-2 text-xs font-bold uppercase tracking-[0.18em] text-cyan-100 shadow-lg shadow-slate-950/40 backdrop-blur transition group-hover:border-cyan-300/45 group-hover:bg-cyan-300/15">
                    <span aria-hidden="true">⤢</span>
                    View larger
                  </span>
                </button>
                <figcaption class="media-caption px-4 py-4">{architectureVisual.caption}</figcaption>
              </figure>

              <dialog id={`architecture-lightbox-${caseStudy.slug}`} class="architecture-lightbox rounded-[1.75rem] border border-cyan-300/20 bg-slate-950/95 p-0 text-white shadow-2xl shadow-slate-950/80 backdrop:bg-slate-950/85 backdrop:backdrop-blur-sm" aria-labelledby={`architecture-lightbox-title-${caseStudy.slug}`}>
                <div class="flex max-h-[92vh] w-[min(94vw,88rem)] flex-col overflow-hidden rounded-[1.75rem]">
                  <div class="flex items-start justify-between gap-4 border-b border-white/10 bg-white/[0.04] px-4 py-4 sm:px-6">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Expanded architecture view</p>
                      <h3 id={`architecture-lightbox-title-${caseStudy.slug}`} class="mt-1 text-lg font-semibold text-white sm:text-xl">{caseStudy.title}</h3>
                    </div>
                    <button type="button" class="architecture-lightbox-close inline-flex size-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.06] text-2xl leading-none text-slate-100 transition hover:border-cyan-300/35 hover:bg-white/[0.1] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300" aria-label="Close expanded architecture view">
                      ×
                    </button>
                  </div>
                  <div class="overflow-auto bg-slate-950 p-3 sm:p-5">
                    <img src={withBase(architectureVisual.src)} alt={architectureVisual.alt} loading="lazy" decoding="async" class="mx-auto max-h-[72vh] min-w-[52rem] rounded-2xl bg-slate-950 object-contain p-3 sm:p-5" />
                  </div>
                  <p class="media-caption border-t border-white/10 bg-white/[0.035] px-4 py-4 sm:px-6">{architectureVisual.caption}</p>
                </div>
              </dialog>
            </div>

            <div class="rounded-[2rem] border border-white/10 bg-white/[0.04] p-5 sm:p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">System explanation</p>
              <h2 id="architecture-system-view" class="mt-3 text-3xl font-semibold tracking-tight text-white">{caseStudy.sections.architecture.title}</h2>
              <p class="mt-5 leading-8 text-slate-300">{caseStudy.sections.architecture.body}</p>
              {caseStudy.sections.architecture.bullets && (
                <ul class="mt-5 space-y-3">
                  {caseStudy.sections.architecture.bullets.map((bullet) => (
                    <li class="flex gap-3 text-sm leading-6 text-slate-300">
                      <span class="mt-2 size-1.5 shrink-0 rounded-full bg-cyan-300"></span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              )}

              <div class="mt-7 border-t border-white/10 pt-6">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Architecture flow</p>
                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                  {caseStudy.flow.map((step, index) => (
                    <div class="rounded-3xl border border-white/10 bg-slate-950/45 p-4">
                      <span class="text-xs font-semibold text-cyan-300">{String(index + 1).padStart(2, "0")}</span>
                      <p class="mt-3 text-sm font-semibold text-white">{step}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>
      )}

      {remainingGallery && remainingGallery.length > 0 && (
        <section class="mt-12" aria-labelledby="evidence">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Real evidence</p>
              <h2 id="evidence" class="mt-3 text-3xl font-semibold tracking-tight text-white">Additional visuals</h2>
            </div>
          </div>

          <div class="mt-8 grid gap-5 md:grid-cols-2">
            {remainingGallery.map((item, index) => (
              <figure class:list={["group browser-frame transition hover:-translate-y-1 hover:border-cyan-300/25", index === 0 ? "md:col-span-2" : ""]}>
                <img src={withBase(item.src)} alt={item.alt} loading="lazy" decoding="async" class:list={["w-full bg-slate-950 object-cover object-top", index === 0 ? "aspect-[16/8]" : "aspect-[16/10]"]} />
                <figcaption class="media-caption px-4 py-4">{item.caption}</figcaption>
              </figure>
            ))}
          </div>
        </section>
      )}

      <div class="mt-12 grid gap-5 md:grid-cols-2">
        {sections.map((section) => (
          <section class="section-reveal surface-soft p-6 transition hover:border-cyan-300/25 hover:bg-white/[0.06]">
            <h2 class="text-2xl font-semibold text-white">{section.title}</h2>
            <p class="mt-4 leading-8 text-slate-300">{section.body}</p>
            {section.bullets && (
              <ul class="mt-5 space-y-3">
                {section.bullets.map((bullet) => (
                  <li class="flex gap-3 text-sm leading-6 text-slate-300">
                    <span class="mt-2 size-1.5 shrink-0 rounded-full bg-cyan-300"></span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            )}
          </section>
        ))}
      </div>

        <nav class="mt-14 grid gap-4 sm:grid-cols-2" aria-label="Case study navigation">
        {previous ? (
          <a href={withBase(`/proyectos/${previous.slug}`)} class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 transition hover:-translate-y-1 hover:border-cyan-300/30 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300">
            <span class="text-sm text-slate-400">Previous</span>
            <span class="mt-2 block text-lg font-semibold text-white">{previous.title}</span>
          </a>
        ) : <div></div>}
        {next && (
          <a href={withBase(`/proyectos/${next.slug}`)} class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 text-left transition hover:-translate-y-1 hover:border-cyan-300/30 sm:text-right focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300">
            <span class="text-sm text-slate-400">Next</span>
            <span class="mt-2 block text-lg font-semibold text-white">{next.title}</span>
          </a>
        )}
      </nav>
    </div>
  </article>

  <Footer />
</BaseLayout>

<script>
  const architectureTriggers = document.querySelectorAll<HTMLButtonElement>(".architecture-lightbox-trigger");

  architectureTriggers.forEach((trigger) => {
    const targetId = trigger.dataset.lightboxTarget;
    const dialog = targetId ? document.getElementById(targetId) : null;

    if (!(dialog instanceof HTMLDialogElement)) return;

    trigger.addEventListener("click", () => {
      if (!dialog.open) {
        dialog.showModal();
      }
    });
  });

  document.querySelectorAll<HTMLDialogElement>(".architecture-lightbox").forEach((dialog) => {
    dialog.querySelector<HTMLButtonElement>(".architecture-lightbox-close")?.addEventListener("click", () => {
      dialog.close();
    });

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  });
</script>
