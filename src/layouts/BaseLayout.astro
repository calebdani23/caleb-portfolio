---
import "../styles/global.css";

const {
  title = "Caleb Perez — AI Product Builder",
  description = "Portafolio personal de Caleb Perez: IA, travel tech, automatización, servidores y desarrollo de producto.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main class="min-h-screen">
      <slot />
    </main>
  </body>
</html>
