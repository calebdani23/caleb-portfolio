---
import CertificationsSection from "../components/CertificationsSection.astro";
import ContactSection from "../components/ContactSection.astro";
import FeaturedProject from "../components/FeaturedProject.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Navigation from "../components/Navigation.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SportsSection from "../components/SportsSection.astro";
import TechStack from "../components/TechStack.astro";
import Timeline from "../components/Timeline.astro";
import WorkMethod from "../components/WorkMethod.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { certifications } from "../data/certifications";
import { featuredProject, projects } from "../data/projects";
import { sportsHighlights } from "../data/sports";
import { stackGroups } from "../data/stack";
import { timelineItems } from "../data/timeline";
import { workSteps } from "../data/workMethod";

const secondaryProjects = projects.filter((project) => project !== featuredProject);
---

<BaseLayout
  title="Caleb Perez — AI Product Builder & Travel Tech Builder"
  description="Portafolio de Caleb Perez: productos digitales con IA, travel tech, automatización, servidores propios, UX/UI y desarrollo de software."
>
  <Navigation />
  <Hero />

  <section id="sobre-mi" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <SectionHeader
        eyebrow="Sobre mí"
        title="No vengo de un camino lineal; por eso construyo con más contexto."
        description="Soy de Playa del Carmen, México. Mi camino pasó por Finanzas, Ingeniería Civil, tecnología, aprendizaje autodidacta y una etapa viviendo en Nueva Zelanda; esa mezcla me enseñó a moverme con incertidumbre y a construir con visión práctica."
      />

      <div class="section-reveal grid gap-5 md:grid-cols-2">
        <article class="premium-card p-6 md:col-span-2">
          <p class="text-lg leading-8 text-slate-300">
            Hoy estoy construyendo Zalmar Travel conectando dos mundos muy reales en mi vida: la operación de viajes que he visto de cerca durante años por el trabajo de mi mamá en agencias, y mi compromiso actual con software, IA y producto digital.
          </p>
        </article>
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <p class="text-sm font-semibold text-cyan-300">Mentalidad</p>
          <h3 class="mt-3 text-xl font-semibold text-white">Aprender construyendo</h3>
          <p class="mt-3 leading-7 text-slate-300">Google, Oracle/Alura y proyectos propios reforzaron algo clave: puedo avanzar por mi cuenta cuando el objetivo es suficientemente real.</p>
        </article>
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <p class="text-sm font-semibold text-cyan-300">Foco actual</p>
          <h3 class="mt-3 text-xl font-semibold text-white">Travel tech con IA</h3>
          <p class="mt-3 leading-7 text-slate-300">Zalmar Travel concentra mi interés por booking, automatización, UX, APIs y agentes que acompañan decisiones.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="proyectos" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <SectionHeader
          eyebrow="Proyectos destacados"
          title="Un sistema principal en curso, rodeado por piezas que explican cómo pienso producto."
          description="Zalmar Travel es el proyecto central: concentra travel tech, IA, UX, APIs y operación real. Alrededor viven otros case studies que muestran arquitectura, infraestructura, automatización y diseño de experiencias."
        />
        <div class="section-reveal rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6">
          <p class="text-sm font-semibold text-cyan-300">Cómo se organiza</p>
          <p class="mt-3 leading-7 text-slate-300">
            Zalmar abre la sección como producto principal; después aparecen piezas que amplían el contexto técnico sin repetir el mismo caso.
          </p>
        </div>
      </div>

      <div class="mt-12">
        <FeaturedProject project={featuredProject} />
      </div>

      <div class="mt-14 border-t border-white/10 pt-10">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Más proyectos</p>
            <h3 class="mt-3 text-3xl font-semibold tracking-tight text-white">Exploraciones que amplían el mismo criterio.</h3>
          </div>
          <p class="max-w-2xl leading-7 text-slate-300">
            Arquitectura de reservas, servidores propios, sistemas UX y el portfolio como plataforma viva: proyectos conectados al mismo enfoque de construir con claridad y evidencia.
          </p>
        </div>

        <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {secondaryProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </div>
  </section>

  <section id="journey" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-6xl">
      <SectionHeader
        eyebrow="Camino"
        title="Una línea de tiempo de curiosidad, práctica y producto."
        description="Mi experiencia no está definida por un solo título, sino por la suma de exploraciones que hoy aterrizan en productos digitales reales."
      />
      <Timeline items={timelineItems} />
    </div>
  </section>

  <CertificationsSection certifications={certifications} />

  <SportsSection highlights={sportsHighlights} />

  <section id="stack" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-7xl">
      <SectionHeader
        eyebrow="Stack técnico"
        title="Tecnología elegida por lo que permite construir, no por moda."
        description="Mi stack mezcla frontend moderno, APIs, IA, infraestructura propia y diseño de producto para cubrir el ciclo completo: idea, flujo, integración, validación y operación."
      />
      <TechStack groups={stackGroups} />
    </div>
  </section>

  <section id="forma-de-trabajo" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-7xl">
      <SectionHeader
        eyebrow="Forma de trabajo"
        title="De problema a producto, con flujos que se pueden tocar."
        description="Me gusta avanzar con criterio: entender, diseñar, construir, integrar, automatizar y validar. La meta no es solo que compile, sino que el producto comunique confianza."
      />
      <WorkMethod steps={workSteps} />
    </div>
  </section>

  <ContactSection />
  <Footer />
</BaseLayout>
