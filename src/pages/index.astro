---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="relative overflow-hidden px-6 py-24 sm:px-10 lg:px-20">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,_rgba(34,211,238,0.22),_transparent_35%),radial-gradient(circle_at_bottom_right,_rgba(14,165,233,0.16),_transparent_40%)]"></div>

    <div class="mx-auto max-w-6xl">
      <p class="mb-5 text-sm font-medium uppercase tracking-[0.35em] text-cyan-300">
        AI · Travel Tech · Product Builder
      </p>

      <h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-white sm:text-7xl">
        Caleb Perez construye productos digitales con IA, automatización y criterio de producto.
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-8 text-slate-300">
        Desarrollo sistemas reales combinando software, diseño UX/UI, APIs, servidores propios y flujos complejos de negocio. Mi foco actual es Zalmar Travel: una plataforma AI-enabled para planear, cotizar y reservar viajes.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#proyectos" class="rounded-full bg-cyan-300 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200">
          Ver proyectos
        </a>
        <a href="mailto:calebdani@icloud.com" class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
          Contactarme
        </a>
      </div>
    </div>
  </section>

  <section id="proyectos" class="px-6 py-20 sm:px-10 lg:px-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10">
        <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-300">Proyectos destacados</p>
        <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Trabajo que cuenta una historia real</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20">
          <p class="text-sm text-cyan-300">Travel Tech · IA · APIs</p>
          <h3 class="mt-3 text-2xl font-semibold text-white">Zalmar Travel</h3>
          <p class="mt-4 text-slate-300">
            Plataforma AI-enabled para planificación, cotización y reserva de viajes con concepto de plan maestro, workspace operativo e integraciones de proveedores.
          </p>
        </article>

        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20">
          <p class="text-sm text-cyan-300">Automation · Ubuntu Server</p>
          <h3 class="mt-3 text-2xl font-semibold text-white">Visual Runner Server</h3>
          <p class="mt-4 text-slate-300">
            Servidor dedicado para validaciones visuales, navegación real, pruebas de flujos y soporte a agentes de desarrollo.
          </p>
        </article>

        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20">
          <p class="text-sm text-cyan-300">Architecture · Booking Flow</p>
          <h3 class="mt-3 text-2xl font-semibold text-white">AI Booking Orchestrator</h3>
          <p class="mt-4 text-slate-300">
            Diseño de orquestación para reservas multi-servicio: vuelos, hoteles, actividades y traslados dentro de un solo plan.
          </p>
        </article>

        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20">
          <p class="text-sm text-cyan-300">UX/UI · Product Design</p>
          <h3 class="mt-3 text-2xl font-semibold text-white">Travel Booking UX System</h3>
          <p class="mt-4 text-slate-300">
            Rediseño conceptual de búsqueda, cotización, workspace y booking para una plataforma travel tech moderna.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
