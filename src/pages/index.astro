---
import CertificationsSection from "../components/CertificationsSection.astro";
import ContactSection from "../components/ContactSection.astro";
import FeaturedProject from "../components/FeaturedProject.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Navigation from "../components/Navigation.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SportsSection from "../components/SportsSection.astro";
import TechStack from "../components/TechStack.astro";
import Timeline from "../components/Timeline.astro";
import WorkMethod from "../components/WorkMethod.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { certifications, recognitionItems } from "../data/certifications";
import { featuredProject, projects } from "../data/projects";
import { sportsHighlights } from "../data/sports";
import { stackGroups } from "../data/stack";
import { timelineItems } from "../data/timeline";
import { workSteps } from "../data/workMethod";

const secondaryProjects = projects.filter((project) => project !== featuredProject);
---

<BaseLayout
  title="Caleb Perez — AI Product Builder & Travel Tech Builder"
  description="Caleb Perez portfolio: AI product building, travel tech, automation, self-hosted systems, UX/UI and software development."
>
  <Navigation />
  <Hero />

  <section id="sobre-mi" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <SectionHeader
        eyebrow="About me"
        title="My path has not been linear — that is why I build with more context."
        description="I am from Playa del Carmen, Mexico. I explored business and finance, moved into engineering looking for the right kind of challenge, found my strongest direction in software and AI, and grew through self-learning and a year living independently in New Zealand."
      />

      <div class="section-reveal grid gap-5 md:grid-cols-2">
        <article class="premium-card p-6 md:col-span-2">
          <p class="text-lg leading-8 text-slate-300">
            I learn by building. Today that means focusing on Zalmar Travel, a travel-tech platform that connects years of close exposure to real agency operations with software, AI agents, UX and product systems.
          </p>
        </article>
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <p class="text-sm font-semibold text-cyan-300">Self-driven learning</p>
          <h3 class="mt-3 text-xl font-semibold text-white">Learning by building</h3>
          <p class="mt-3 leading-7 text-slate-300">Google, Oracle/Alura and independent projects reinforced a key habit: I can learn independently, stay disciplined and move forward when the goal is real enough.</p>
        </article>
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <p class="text-sm font-semibold text-cyan-300">Global independence</p>
          <h3 class="mt-3 text-xl font-semibold text-white">Adaptability under uncertainty</h3>
          <p class="mt-3 leading-7 text-slate-300">Living and working abroad in New Zealand strengthened independence, resilience and the ability to make decisions without perfect conditions.</p>
        </article>
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 md:col-span-2">
          <p class="text-sm font-semibold text-cyan-300">AI + travel tech focus</p>
          <h3 class="mt-3 text-xl font-semibold text-white">A product direction with real operational roots</h3>
          <p class="mt-3 leading-7 text-slate-300">Zalmar Travel concentrates my interest in booking flows, automation, UX, APIs and agents that support decisions instead of hiding them.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="proyectos" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <SectionHeader
          eyebrow="Featured projects"
          title="One main product, supported by projects that show how I think about systems."
          description="Zalmar Travel is the central project: it brings together travel tech, AI, UX, APIs and real operational context. The surrounding projects show architecture, infrastructure, automation and experience design."
        />
        <div class="section-reveal rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6">
            <p class="text-sm font-semibold text-cyan-300">How to read this section</p>
          <p class="mt-3 leading-7 text-slate-300">
             Zalmar leads as the main product. The following projects expand the technical context without pretending every asset is public-ready yet.
          </p>
        </div>
      </div>

      <div class="mt-12">
        <FeaturedProject project={featuredProject} />
      </div>

      <div class="mt-14 border-t border-white/10 pt-10">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
             <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">Supporting projects</p>
             <h3 class="mt-3 text-3xl font-semibold tracking-tight text-white">Explorations that extend the same product judgment.</h3>
          </div>
          <p class="max-w-2xl leading-7 text-slate-300">
             Booking architecture, AI tooling concepts, self-hosted infrastructure and UX systems — each one connected to building with clarity and honest evidence.
          </p>
        </div>

        <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {secondaryProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </div>
  </section>

  <section id="journey" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-6xl">
      <SectionHeader
        eyebrow="Journey / Trajectory"
        title="A chronological path from curiosity to product building."
        description="My experience is not defined by a single title, but by a sequence of explorations that now converge in practical digital products."
      />
      <Timeline items={timelineItems} />
    </div>
  </section>

  <CertificationsSection certifications={certifications} recognitions={recognitionItems} />

  <SportsSection highlights={sportsHighlights} />

  <section id="stack" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-7xl">
      <SectionHeader
          eyebrow="Technical stack"
          title="Technology chosen for what it helps me build — not for trend value."
          description="My stack combines modern frontend, APIs, AI, self-hosted infrastructure and product design to cover the full cycle: idea, flow, integration, validation and operation."
      />
      <TechStack groups={stackGroups} />
    </div>
  </section>

  <section id="forma-de-trabajo" class="px-5 py-20 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-7xl">
      <SectionHeader
        eyebrow="Work process"
        title="From problem to product, with flows people can actually use."
        description="I move through understanding, designing, building, integrating, automating and validating. The goal is not only that it compiles, but that the product communicates trust."
      />
      <WorkMethod steps={workSteps} />
    </div>
  </section>

  <ContactSection />
  <Footer />
</BaseLayout>
